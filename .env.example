# DO NOT COMMIT REAL SECRETS.
# Copy to `.env` and fill in keys:
#
#   cp .env.example .env
#

# ── Required for full functionality ──
OPENROUTER_API_KEY=your_openrouter_api_key_here

# News providers (any subset works; missing keys just disable that source)
NEWSAPI_KEY=your_newsapi_key_here
NEWS_API_KEY=your_newsapi_key_here
GNEWS_API_KEY=your_gnews_api_key_here
NEWSDATA_API_KEY=your_newsdata_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Google Fact Check + Knowledge Graph (optional but recommended)
GOOGLE_FACTCHECK_API_KEY=your_google_factcheck_api_key_here
GOOGLE_FACT_CHECK_API_KEY=your_google_factcheck_api_key_here
GOOGLE_KG_API_KEY=your_google_kg_api_key_here
GOOGLE_KNOWLEDGE_GRAPH_API_KEY=your_google_kg_api_key_here

# Optional legacy keys referenced elsewhere
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GOOGLE_CLOUD_VISION_API_KEY=
GOOGLE_CUSTOM_SEARCH_API_KEY=
OPTIIC_API_KEY=

# ── Model configuration (optional overrides) ──
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
LLM_MODEL_NAME=gpt-4o-mini

MODEL_CLAIM_EXTRACTOR=meta-llama/llama-3.2-3b-instruct
MODEL_QUERY_EXPANDER=meta-llama/llama-3.2-3b-instruct
MODEL_EVIDENCE_ANALYST=qwen/qwen3-next-80b-a3b-instruct
MODEL_FACTCHECK_JUDGE=openai/gpt-oss-120b
MODEL_VALIDATION_AGENT=mistral/mistral-small-3.1-24b
MODEL_NEWS_SUMMARIZER=meta-llama/llama-3.2-3b-instruct

# ── Server configuration ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
